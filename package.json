{
  "name": "video-wall-player",
  "version": "0.0.10",
  "description": "A Vue 3 video wall player component with multi-stream synchronization",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "demo:build": "vite build",
    "demo:dev": "vite",
    "dev": "vite",
    "build": "vite build -c vite.config.lib.ts",
    "bump": "bumpp",
    "changelog": "changelogen --output CHANGELOG.md",
    "release": "pnpm build && pnpm changelog && pnpm bump --all --commit \"chore: release v%s\" --push --tag"
  },
  "keywords": [
    "vue",
    "video",
    "player",
    "video-player",
    "video-wall",
    "multi-stream",
    "wall-player",
    "sync-player"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/huangzida/video-wall-player"
  },
  "author": "huangzida <398926656@qq.com> + https://huangzida.github.io/video-wall-player/",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@vueuse/core": "^10.0.0",
    "lucide-vue-next": "^0.300.0"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "bumpp": "^9.2.0",
    "changelogen": "^0.5.5",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@10.12.4"
}
